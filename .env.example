# Convex Configuration
# Get your deployment URL from the Convex dashboard after running 'bun convex dev'.
CONVEX_DEPLOYMENT=https://your-deployment-url.convex.cloud
CONVEX_URL=https://your-deployment-url.convex.cloud

# PostHog Configuration (Optional)
# Get your API key from PostHog dashboard: https://app.posthog.com/project/settings.
POSTHOG_API_KEY=phc_your_posthog_api_key_here
